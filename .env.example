# ===== API Keys (fill with your own secrets) =====
DART_API_KEY=
KIS_APP_KEY=
KIS_APP_SECRET=
GEMINI_API_KEY=
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
ECOS_API_KEY=
FRED_API_KEY=
KOSIS_API_KEY=
EXIM_API_KEY=
EIA_API_KEY=

# ===== Market/Data =====
KIWOOM_MARKET_TYPE=KOSPI
KIWOOM_QUERY_DATE=
YAHOO_TICKERS=^KS11,^KQ11
PRICE_PERIOD=1y
PRICE_INTERVAL=1d
DART_CORP_CODE=
DART_LOOKBACK_DAYS=365

# ===== Admin Auth =====
SEPA_ADMIN_TOKEN=
SEPA_ADMIN_PREVIOUS_TOKENS=
SEPA_ADMIN_TOKENS=
SEPA_ADMIN_ALLOW_LEGACY_HEADER=1
SEPA_ADMIN_AUDIT_FAILURES=1
SEPA_KIS_ORDER_ENABLED=0

# ===== KIS Broker =====
KIS_ENV=prod
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=
KIS_BASE_URL=

# ===== LLM =====
SEPA_LLM_PROVIDER=ollama
SEPA_LLM_TIMEOUT_SECONDS=60
SEPA_LLM_TEMPERATURE=0.2
SEPA_LLM_MAX_HISTORY_MESSAGES=8
OLLAMA_BASE_URL=http://127.0.0.1:11434
SEPA_OLLAMA_MODEL=qwen3.5:4b
SEPA_GEMINI_MODEL=gemini-2.5-flash

# ===== Runtime =====
DB_PATH=./.omx/artifacts/quant.db
DOCS_DIR=./docs
API_HOST=127.0.0.1
API_PORT=8000
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=8080
SEPA_CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
SEPA_CORS_ALLOW_CREDENTIALS=0
SEPA_ENABLE_DOCS=0
SEPA_RATE_LIMIT_API_RPM=120
SEPA_RATE_LIMIT_STATIC_RPM=300
SEPA_RATE_LIMIT_WINDOW_SECONDS=60
SEPA_RATE_LIMIT_TRUST_PROXY_HEADERS=0
SEPA_RATE_LIMIT_TRUSTED_PROXY_IPS=
PIPELINE_MODE=alpha_only
SEPA_INSTALL_DEPS=auto
SEPA_KILL_EXISTING_PORTS=0
SEPA_RUN_AFTER_CLOSE=1
SEPA_BACKFILL_DAYS=84
SEPA_OPEN_BROWSER=1

# ===== Kiwoom REST Endpoints (optional for live mode) =====
KIWOOM_TOKEN_URL=
KIWOOM_OHLCV_URL=
SEPA_SYMBOLS=005930.KS,000660.KS,051910.KS
SEPA_LIVE_MODE=0
SEPA_MIN_REAL_HISTORY_DAYS=1600
