# ============================================================
# ky-platform environment template
# Shared secrets live in ~/.ky-platform/shared.env (loaded first by scripts/dev.*)
# This file holds project-local overrides ONLY — never put API keys here.
# ============================================================

# ---- Local services ----
# Uncommon ports so ky-platform doesn't collide with the user's many
# other Desktop projects running on 3xxx/5xxx/8xxx. gazua.yule.pics and
# alpha.yule.pics tunnel to these via Cloudflared.
API_HOST=127.0.0.1
API_PORT=31300
WEB_HOST=127.0.0.1
WEB_PORT=31380

# ---- Multi-tenancy (current operator = self) ----
PLATFORM_OWNER_ID=self

# ---- Feature flags ----
ENABLE_STOCK_MODAL=1
ENABLE_TICKER_TAPE=1

# ---- Backend config ----
LOG_LEVEL=INFO
CORS_ORIGINS=http://127.0.0.1:31380,http://localhost:31380,https://gazua.yule.pics,https://alpha.yule.pics

# ---- Frontend → Backend ----
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:31300

# ---- Secrets belong in ~/.ky-platform/shared.env (DO NOT COMMIT) ----
# KIS_APP_KEY=
# KIS_APP_SECRET=
# KIWOOM_APP_KEY=
# KIWOOM_SECRET_KEY=
# DART_API_KEY=
# FRED_API_KEY=
# ECOS_API_KEY=
# KOSIS_API_KEY=
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
