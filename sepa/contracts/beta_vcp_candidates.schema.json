{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BetaVcpCandidates",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["symbol", "confidence"],
    "properties": {
      "symbol": {"type": "string"},
      "waves": {"type": "integer", "minimum": 2, "maximum": 6},
      "contraction_ratio": {"type": "number"},
      "volume_dryup": {"type": "number"},
      "confidence": {"type": "number", "minimum": 0, "maximum": 10}
    }
  }
}
